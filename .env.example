# Sketch.AI Environment Variables

# OpenAI API Key (Required for online mode)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Optional: OpenAI Organization ID
# OPENAI_ORG_ID=org-your-org-id

# Optional: Base URL for OpenAI API (for proxies or alternative endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: OpenAI model overrides (online mode)
# OPENAI_TEXT_MODEL=gpt-5.2
# OPENAI_VISION_MODEL=gpt-4o

# ========================================
# OFFLINE MODE (Local Models via Ollama)
# ========================================
# Set to 'true' to use local Ollama models instead of OpenAI
USE_OFFLINE_MODEL=false

# Ollama server URL (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Model overrides (defaults shown):
# OLLAMA_VISION_MODEL=qwen3-vl:8b
# OLLAMA_TEXT_MODEL=deepseek-coder-v2:16b

# Recommended Ollama models for M3 24GB:
# - qwen3-vl:8b (vision - best for 3D spatial understanding)
# - deepseek-coder-v2:16b (text/JSON generation)
# - qwen2.5-coder:14b (faster alternative for text)
#
# Install: ollama pull qwen3-vl:8b && ollama pull deepseek-coder-v2:16b

# ========================================
# CAD + RENDER (OPTIONAL)
# ========================================
# CadQuery Python executable (must have cadquery installed)
# CADQUERY_PYTHON=python3

# Blender binary path (used for photoreal renders)
# BLENDER_PATH=/Applications/Blender.app/Contents/MacOS/Blender

# Tavily API Key (Optional: enables web search for component pricing)
# TAVILY_API_KEY=tvly-your-key-here

# Logging
# LOG_LEVEL=info
# LOG_FORMAT=json

